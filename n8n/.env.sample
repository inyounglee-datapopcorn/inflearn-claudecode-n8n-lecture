# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=n8n

# n8n Basic Auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here
N8N_ENCRYPTION_KEY=your_encryption_key_here  # openssl rand -hex 24

# n8n Public API — generate in n8n UI (Settings > API)
N8N_HOST_URL=http://localhost:5678/
N8N_API_KEY=your_n8n_api_key_here

# n8n Public API (remote - win)
N8N_REMOTE_HOST_URL=https://your-n8n-win-domain/
N8N_REMOTE_API_KEY=your_remote_win_api_key_here

# n8n Public API (remote - xyz)
N8N_REMOTE_XYZ_HOST_URL=https://your-n8n-xyz-domain/
N8N_REMOTE_XYZ_API_KEY=your_remote_xyz_api_key_here

# Slack Bot Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# GitHub PAT for workflow backup (scope: Contents R/W on target repo)
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_BACKUP_OWNER=your-github-username
GITHUB_BACKUP_REPO=n8n-workflow-backup
GITHUB_BACKUP_BRANCH=main
