    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst response = $input.first().json;\nconst currentWorkflows = response.data || [];\n\nconst currentIds = currentWorkflows.map(w => w.id);\nconst knownIds = staticData.knownWorkflowIds || [];\n\n// 신규 워크플로우 = 현재 목록에 있지만 이전에 없던 것\nconst newWorkflows = currentWorkflows.filter(w => !knownIds.includes(w.id));\n\n// Static Data 항상 최신 목록으로 갱신\nstaticData.knownWorkflowIds = currentIds;\n\nif (newWorkflows.length === 0) {\n  return [];\n}\n\nreturn newWorkflows.map(w => ({\n  json: {\n    id: w.id,\n    name: w.name,\n    active: w.active,\n    createdAt: w.createdAt,\n    nodeCount: w.nodeCount || 0,\n    tags: (w.tags || []).map(t => t.name).join(', ') || '없음',\n    url: 'http://localhost:5678/workflow/' + w.id\n  }\n}));"
      },
      "id": "node-code",
      "name": "신규 워크플로우 감지",
