      "name": "워크플로우 목록 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        464,
        208
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "oP1jT7pXYnguB34O",
          "name": "n8n Public API (X-N8N-API-KEY)"
        }
      },
      "notes": "n8n API로 전체 워크플로우 목록 조회"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// lastChecked 없으면 1시간 전 기준 (방금 만든 워크플로우도 포함)\nconst lastChecked = staticData.lastChecked\n  ? new Date(staticData.lastChecked)\n  : new Date(Date.now() - 60 * 60 * 1000);\n\nconst response = $input.first().json;\nconst allWorkflows = response.data || [];\n\n// lastChecked 이후 생성된 워크플로우 감지\nconst newWorkflows = allWorkflows.filter(function(w) {\n  return new Date(w.createdAt) > lastChecked;\n});\n\n// 현재 시각으로 갱신 (다음 실행의 기준점)\nstaticData.lastChecked = new Date().toISOString();\n\nif (newWorkflows.length === 0) {\n  return [{ json: { hasNew: false } }];\n}\n\nconst lines = newWorkflows.map(function(w) {\n  const createdAt = new Date(w.createdAt).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' });\n  return '\\u2022 *' + w.name + '* | ID: `' + w.id + '` | \\uc0dd\\uc131: ' + createdAt;\n});\nconst message = '\\ud83c\\udd95 *\\uc2e0\\uaddc \\uc6cc\\ud06c\\ud50c\\ub85c\\uc6b0 \\uac10\\uc9c0* (' + newWorkflows.length + '\\uac1c)\\n' + lines.join('\\n');\n\nreturn [{ json: { hasNew: true, count: newWorkflows.length, message: message } }];"
      },
      "id": "node-3",
      "name": "신규 워크플로우 감지",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        208
      ],
      "notes": "Static Data로 기존 ID 유지, 신규 감지 및 Slack 메시지 포맷"
    },
    {
      "parameters": {
