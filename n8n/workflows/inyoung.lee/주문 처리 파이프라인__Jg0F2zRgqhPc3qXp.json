      "parameters": {
        "jsCode": "// [의도적 에러] items 배열 없는 불완전한 주문 데이터\nreturn [{ json: { orderId: 'ORD-20240427-001', customerId: 'CUST-001', status: 'pending', items: [{ name: '상품A', price: 15000 }, { name: '상품B', price: 25000 }] } }];"
      },
      "id": "c2",
      "name": "주문 데이터 수신",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        304
      ],
      "notes": "items 배열을 의도적으로 제외"
    },
    {
      "parameters": {
        "jsCode": "const order = $input.first().json;\n\n// order.items가 undefined — reduce 호출 시 TypeError 발생 (로직 에러)\nconst total = order.items.reduce((sum, item) => sum + item.price, 0);\nconst tax = total * 0.1;\n\nreturn [{ json: { orderId: order.orderId, total, tax, grandTotal: total + tax } }];"
      },
      "id": "c3",
      "name": "주문 금액 계산",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        304
      ],
      "notes": "items.reduce 호출 — TypeError 유발 지점"
    },
    {
      "parameters": {
        "jsCode": "const order = $input.first().json;\nreturn [{ json: { to: 'customer@example.com', subject: `주문 ${order.orderId} 처리 완료`, amount: order.grandTotal } }];"
      },
