        "assignments": {
          "assignments": [
            {
              "id": "mp-001",
              "name": "json_master",
              "type": "string",
              "value": "{\n  \"description\": \"Brief narrative description of the scene.\",\n  \"style\": \"cinematic | photorealistic | stylized | gritty | elegant\",\n  \"camera\": {\n    \"type\": \"fixed | dolly | Steadicam | crane combo\",\n    \"movement\": \"describe any camera moves\",\n    \"lens\": \"optional lens type\"\n  },\n  \"lighting\": {\n    \"type\": \"natural | dramatic | high-contrast\",\n    \"sources\": \"key lighting sources\",\n    \"FX\": \"optional VFX elements\"\n  },\n  \"environment\": {\n    \"location\": \"describe location\",\n    \"set_pieces\": [\"key background or prop elements\"],\n    \"mood\": \"ambient atmosphere\"\n  },\n  \"elements\": [\"main physical items involved\"],\n  \"subject\": {\n    \"character\": {\"description\": \"optional\", \"pose\": \"optional\", \"lip_sync_line\": \"optional\"},\n    \"product\": {\"brand\": \"Brand name\", \"model\": \"Product model\", \"action\": \"product transformation\"}\n  },\n  \"motion\": {\"type\": \"transformation, explosion, vortex\", \"details\": \"step-by-step visual flow\"},\n  \"VFX\": {\"transformation\": \"optional\", \"impact\": \"optional\", \"particles\": \"optional\", \"environment\": \"optional\"},\n  \"audio\": {\n    \"music\": \"optional\",\n    \"sfx\": [\"sound effects\"],\n    \"ambience\": \"optional\",\n    \"voiceover\": {\"delivery\": \"tone and style\", \"line\": \"text spoken\"}\n  },\n  \"ending\": \"Final shot description\",\n  \"text\": \"none | overlay | tagline | logo pulse at end only\",\n  \"format\": \"16:9 | 4k | vertical\",\n  \"keywords\": [\"brand\", \"scene style\", \"motion type\", \"camera style\", \"sound mood\", \"target theme\"]\n}"
            }
          ]
        },
        "options": {}
