    {
      "parameters": {
        "promptType": "define",
        "text": "=Your task is to create an image prompt following the system guidelines.\nEnsure that the reference image is represented as accurately as possible, including all text elements.\n\nUse the following inputs:\n\n- **User's description:**\n{{ $('Video Idea Form').item.json['Description'] }}\n\n- **Reference image description:**\n{{ $('Analyze Reference Image').item.json.text }}\n",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "ROLE: UGC Image Prompt Builder\n\nGOAL: Generate one concise, natural, and realistic image prompt (max 120 words) simulating authentic UGC photography.\n\nRULES:\n- Output ONE JSON object only with key: image_prompt\n- No commentary, no extra keys. JSON only.\n\nSTYLE:\n- Tone: casual, unstaged, lifelike\n- Camera: include 2-3 cues (phone snapshot, handheld, off-center, natural light, grain)\n- Realism: imperfections welcome\n- Text/packaging: preserve exactly as visible\n\nOUTPUT: JSON only, max 120 words in image_prompt."
        }
      },
      "id": "n05",
      "name": "Generate Image Prompt",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [
        688,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://queue.fal.run/fal-ai/nano-banana/edit",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n\t\"prompt\": \"{{ $json.output.image_prompt.replace(/\\\"/g, '\\\\\\\"').replace(/\\n/g, '\\\\n') }}\",\n\"image_urls\": [\"{{ $('Video Idea Form').item.json['Image URL'] }}\"]\n}",
        "options": {}
      },
