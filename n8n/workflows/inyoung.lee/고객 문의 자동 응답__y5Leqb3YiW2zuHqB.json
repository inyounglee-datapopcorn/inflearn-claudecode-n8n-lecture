      "notes": "email 필드를 의도적으로 제외한 테스트 데이터"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// email 필드 검증 — 누락 시 에러 발생\nif (!item.email || item.email.trim() === '') {\n  throw new Error('[데이터 에러] 필수 필드 누락: email\\n고객 문의 데이터에 email 주소가 없습니다. 폼 수집 시 email 필드를 필수로 설정하세요.');\n}\n\nreturn [{ json: { to: item.email, subject: '문의 접수 확인', body: `${item.customer_name}님, 문의가 접수되었습니다.` } }];"
      },
