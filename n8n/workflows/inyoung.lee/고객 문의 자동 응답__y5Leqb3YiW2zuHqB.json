        "jsCode": "// [의도적 에러] email 필드가 없는 불완전한 고객 데이터\nreturn [{ json: { customer_name: '홍길동', inquiry: '배송 조회 문의드립니다.', phone: '010-1234-5678', email: 'hong@example.com' } }];"
