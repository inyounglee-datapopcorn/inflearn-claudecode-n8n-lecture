      },
      "id": "uc1-4",
      "name": "뉴스 RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1.2,
      "position": [
        912,
        304
      ],
      "notes": "Google 뉴스 한국판 RSS - API 키 불필요"
    },
    {
      "parameters": {
        "jsCode": "const w = $('날씨 API').first().json;\nconst temp = Math.round(w.current?.temperature_2m ?? 0);\nconst humidity = w.current?.relative_humidity_2m ?? '-';\nconst wind = w.current?.wind_speed_10m ?? '-';\nconst code = w.current?.weather_code ?? 0;\nconst wmoDesc = {0:'맑음',1:'대체로 맑음',2:'구름 조금',3:'흐림',45:'안개',48:'안개',51:'이슬비',53:'이슬비',55:'이슬비',61:'비',63:'비',65:'강한 비',71:'눈',73:'눈',75:'강한 눈',80:'소나기',81:'소나기',82:'강한 소나기',95:'뇌우',96:'뇌우(우박)',99:'뇌우(우박)'};\nconst desc = wmoDesc[code] ?? '맑음';\n\nconst fx = $('환율 API').first().json;\nconst krw = fx.rates?.KRW ? Math.round(fx.rates.KRW).toLocaleString('ko-KR') : '?';\nconst jpy = fx.rates?.JPY ? fx.rates.JPY.toFixed(1) : '?';\nconst eur = fx.rates?.EUR ? fx.rates.EUR.toFixed(4) : '?';\n\nconst news = $input.all().slice(0,5).map((n,i)=>`${i+1}. ${n.json.title??''}`).join('\\n');\nconst today = new Date().toLocaleDateString('ko-KR',{timeZone:'Asia/Seoul'});\n\nreturn [{\n  json: {\n    today,\n    weatherInfo: `${temp}°C, ${desc}, 습도 ${humidity}%, 바람 ${wind}m/s`,\n    fxInfo: `USD/KRW ${krw}원 / USD/JPY ${jpy}엔 / USD/EUR ${eur}`,\n    newsText: news\n  }\n}];"
      },
      "id": "uc1-5",
      "name": "데이터 병합",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        304
      ],
      "notes": "날씨·환율·뉴스 정리 → OpenAI 노드에서 표현식으로 사용"
