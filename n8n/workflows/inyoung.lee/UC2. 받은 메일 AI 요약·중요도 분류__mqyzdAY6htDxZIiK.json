  "name": "UC2. 받은 메일 AI 요약·중요도 분류",
  "description": null,
  "active": false,
  "isArchived": false,
  "nodes": [
    {
      "id": "uc2-1",
      "name": "Gmail 수신 감지",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {},
        "simple": true,
        "options": {}
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "vhs04Ni72VVCoTo1",
          "name": "Gmail account"
        }
      },
      "notes": "수신 메일 폴링 (1분 간격)"
    },
    {
      "id": "uc2-2",
      "name": "메일 추출 + 프롬프트",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        300
      ],
      "parameters": {
        "jsCode": "const mail = $json;\nconst subject = mail.subject ?? '(제목 없음)';\nconst from = mail.from?.value?.[0]?.address ?? String(mail.from ?? '알 수 없음');\nconst body = (mail.text ?? mail.html?.replace(/<[^>]*>/g,'') ?? '').slice(0,1200);\n\nreturn [{json:{\n  _subject: subject,\n  _from: from,\n  model:'gpt-4o-mini',\n  messages:[\n    {role:'system', content:'이메일 분석 후 JSON으로만 응답: {\"summary\":\"요약2줄\",\"priority\":\"High|Mid|Low\",\"action_needed\":true|false,\"reason\":\"이유\"}'},\n    {role:'user', content:`발신자: ${from}\\n제목: ${subject}\\n본문:\\n${body}`}\n  ],\n  max_tokens:250\n}}];"
      },
      "notes": "메일 내용 추출 및 OpenAI 요청 본문 구성"
    },
    {
      "id": "uc2-3",
      "name": "OpenAI 분석",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        840,
        300
      ],
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({model: $json.model, messages: $json.messages, max_tokens: $json.max_tokens}) }}",
        "options": {}
      },
      "notes": "메일 요약 및 우선순위 분류"
    },
    {
      "id": "uc2-4",
      "name": "응답 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        300
      ],
      "parameters": {
        "jsCode": "const content = $json.choices?.[0]?.message?.content ?? '{}';\nconst prev = $('메일 추출 + 프롬프트').first().json;\nlet parsed;\ntry {\n  const m = content.match(/\\{[\\s\\S]*\\}/);\n  parsed = m ? JSON.parse(m[0]) : {summary:content, priority:'Mid', action_needed:false, reason:''};\n} catch(e) {\n  parsed = {summary:content, priority:'Mid', action_needed:false, reason:''};\n}\nreturn [{json:{...parsed, subject:prev._subject, from:prev._from}}];"
      },
      "notes": "OpenAI JSON 응답 파싱"
    },
    {
      "id": "uc2-5",
      "name": "중요도 필터",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1440,
        300
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.priority }}",
              "rightValue": "Low",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "notes": "Low 우선순위 제외, High/Mid만 Slack 알림"
    },
    {
      "id": "uc2-6",
      "name": "Slack 알림",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1740,
        300
      ],
      "parameters": {
        "url": "={{ $env.SLACK_WEBHOOK_URL }}",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({attachments:[{color: $json.priority==='High'?'danger':'warning', title: ($json.priority==='High'?'🔴':'🟡')+' ['+$json.priority+'] '+$json.subject, text: '*발신자:* '+$json.from+'\\n*요약:* '+$json.summary+($json.action_needed?'\\n⚡️ 조치 필요':''), footer:'n8n 메일 요약 봇'}]}) }}",
        "options": {}
      },
      "notes": "색상 구분 Attachment로 Slack 전송"
    }
  ],
